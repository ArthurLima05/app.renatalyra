    {
      "parameters": {
        "httpMethod": "POST",
        "path": "whatsapp-resposta",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [5296, 10400],
      "id": "199379c9-77a0-4bbf-a9a3-c615bea79e77",
      "name": "Webhook Resposta",
      "webhookId": "9bd352d7-32a4-4af6-86fe-5565d1260ad1"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.item.json;\nconst body = input.body || input;\n\nconst fromMe = body.data?.key?.fromMe ?? false;\nif (fromMe) return [];\n\nconst senderPn = body.data?.key?.senderPn || '';\nlet phone = senderPn.replace('@s.whatsapp.net', '').replace(/\\D/g, '');\n\nif (!phone) {\n  const remoteJid = body.data?.key?.remoteJid || '';\n  phone = remoteJid.replace('@s.whatsapp.net', '').replace('@lid', '').replace(/\\D/g, '');\n}\n\nif (phone.length === 12 && phone.startsWith('55')) {\n  phone = phone.slice(0, 4) + '9' + phone.slice(4);\n}\n\nconst rawText =\n  body.data?.message?.conversation ||\n  body.data?.message?.extendedTextMessage?.text ||\n  body.message?.conversation ||\n  body.text ||\n  '';\n\nconst text = rawText\n  .toLowerCase()\n  .normalize('NFD')\n  .replace(/[\\u0300-\\u036f]/g, '')\n  .trim();\n\nlet action = 'none';\n\nif (/^(sim|s|yes|ok|pode|confirmo|confirmado|confirmar|claro|com certeza|topo|1)$/.test(text)) {\n  action = 'confirm';\n} else if (/^(nao|n|no|nope|cancela|cancelar|cancelado|2)$/.test(text)) {\n  action = 'cancel';\n} else if (/^(remarcar|remarco|reagendar|reagendo|mudar|alterar|trocar|3)$/.test(text) || /remarc|reagend/.test(text)) {\n  action = 'remarcar';\n} else if (/^(agendar|agendo|quero agendar|quero marcar|marcar consulta|4)$/.test(text) || /quero agendar|quero marcar/.test(text)) {\n  action = 'agendar';\n}\n\nreturn [{ json: { action, phone, rawText } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [5536, 10400],
      "id": "df3a16ba-27d8-4d72-92d4-eb3f22d38b4e",
      "name": "Interpretar Resposta"
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2},
                "conditions": [{"id": "sw-confirm", "leftValue": "={{ $json.action }}", "rightValue": "confirm", "operator": {"type": "string", "operation": "equals"}}],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "Confirmar"
            },
            {
              "conditions": {
                "options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2},
                "conditions": [{"id": "sw-cancel", "leftValue": "={{ $json.action }}", "rightValue": "cancel", "operator": {"type": "string", "operation": "equals"}}],
                "combinator": "and"
