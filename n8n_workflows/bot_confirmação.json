    {
      "parameters": {
        "jsCode": "return $input.all().map(i => {\n  const item = i.json;\n  const datePart = item.date.split('T')[0];\n  const appointmentStr = `${datePart}T${item.time}:00-03:00`;\n  const appointmentDate = new Date(appointmentStr);\n  const now = new Date();\n  const hoursUntil = (appointmentDate - now) / (1000 * 60 * 60);\n  return { ...item, hoursUntil: Math.round(hoursUntil) };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-600, 200],
      "id": "bc04-calc-hours",
      "name": "Calcular Horas"
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
          "conditions": [
            { "id": "c24h-gte", "leftValue": "={{ $json.hoursUntil }}", "rightValue": 23, "operator": { "type": "number", "operation": "gte" } },
            { "id": "c24h-lte", "leftValue": "={{ $json.hoursUntil }}", "rightValue": 25, "operator": { "type": "number", "operation": "lte" } }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
