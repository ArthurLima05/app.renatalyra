    {
      "parameters": {
        "jsCode": "const baseMsg = $('Buscar Agendamentos').first().json.confirmationMessage\n  || 'Olá {{nome_paciente}}, sua consulta está marcada para {{data}} às {{hora}}.';\n\nconst prefix = '📋 Ainda aguardamos sua confirmação.\\n\\n';\nconst instruction = '\\n\\nResponda:\\n✅ *SIM* para confirmar\\n❌ *NÃO* para cancelar\\n🔄 *REMARCAR* para remarcar';\n\nreturn $('12h Antes?').all().map(item => {\n  const patient = item.json.patients;\n  if (!patient?.phone) return { json: { skip: true } };\n  const datePart = item.json.date.split('T')[0];\n  const dateStr = new Date(datePart + 'T12:00:00').toLocaleDateString('pt-BR');\n  const msg = prefix + baseMsg\n    .replace(/\\{\\{nome_paciente\\}\\}/g, patient.full_name)\n    .replace(/\\{\\{data\\}\\}/g, dateStr)\n    .replace(/\\{\\{hora\\}\\}/g, item.json.time)\n    + instruction;\n  return { json: { jsonBody: { number: patient.phone, text: msg } } };\n});"
      },
