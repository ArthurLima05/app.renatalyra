    {
      "parameters": {
        "jsCode": "const input = $input.item.json;\nconst body = input.body || input;\n\nconst fromMe = body.data?.key?.fromMe ?? false;\n\n// Ignorar mensagens enviadas pelo próprio bot\nif (fromMe) return [];\n\n// Nova versão do Evolution API fornece senderPn com o número real do remetente\nconst senderPn = body.data?.key?.senderPn || '';\nlet phone = senderPn.replace('@s.whatsapp.net', '').replace(/\\D/g, '');\n\n// Fallback: tenta remoteJid se senderPn não estiver disponível\nif (!phone) {\n  const remoteJid = body.data?.key?.remoteJid || '';\n  phone = remoteJid.replace('@s.whatsapp.net', '').replace('@lid', '').replace(/\\D/g, '');\n}\n\n// Adicionar 9 após DDD para números brasileiros sem o dígito (12 → 13 dígitos)\n// Ex: 558185916795 → 5581985916795\nif (phone.length === 12 && phone.startsWith('55')) {\n  phone = phone.slice(0, 4) + '9' + phone.slice(4);\n}\n\nconst rawText =\n  body.data?.message?.conversation ||\n  body.data?.message?.extendedTextMessage?.text ||\n  body.message?.conversation ||\n  body.text ||\n  '';\n\nconst text = rawText\n  .toLowerCase()\n  .normalize('NFD')\n  .replace(/[\\u0300-\\u036f]/g, '')\n  .trim();\n\nlet action = 'none';\n\nif (/^(sim|s|yes|ok|pode|confirmo|confirmado|confirmar|claro|com certeza|topo|1)$/.test(text)) {\n  action = 'confirm';\n} else if (/^(nao|n|no|nope|cancela|cancelar|cancelado|2)$/.test(text)) {\n  action = 'cancel';\n} else if (\n  /^(remarcar|remarco|reagendar|reagendo|mudar|alterar|trocar|3)$/.test(text) ||\n  text.includes('remarc') ||\n  text.includes('reagend') ||\n  text.includes('outro dia') ||\n  text.includes('outro horario')\n) {\n  action = 'remarcar';\n}\n\nreturn [{ json: { action, phone, rawText } }];"
      },
      "type": "n8n-nodes-base.code",
