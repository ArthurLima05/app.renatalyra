        "jsCode": "const input = $input.first().json;\nconsole.log(`✅ WhatsApp enviado para ${$('Validar Dados').first().json.patientName} (${$('Validar Dados').first().json.patientPhone})`);\nreturn [{ json: { success: true, ...input } }];"
