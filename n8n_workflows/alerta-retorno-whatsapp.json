      "id": "35a9c691-eb11-4456-b665-7836e1fc7ff7",
      "name": "Enviar WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2288, 1328]
    },
    {
      "parameters": {
        "jsCode": "// O body chega como string JSON (Content-Type: text/plain via no-cors)\nconst raw = $input.first().json;\nlet data;\nif (typeof raw.body === 'string') {\n  data = JSON.parse(raw.body);\n} else if (typeof raw.body === 'object' && raw.body !== null) {\n  data = raw.body;\n} else {\n  data = raw;\n}\n\nconst patientName = data.patientName || '';\nconst patientPhone = data.patientPhone || '';\nconst message = data.message || '';\nconst returnDate = data.returnDate || '';\nconst notes = data.notes || '';\n\nif (!patientPhone || !message) {\n  throw new Error(`Dados incompletos: phone=${patientPhone}, message=${message}`);\n}\n\nlet phone = patientPhone.replace(/\\D/g, '');\nif (!phone.startsWith('55')) {\n  phone = '55' + phone;\n}\n\nreturn [{\n  json: { patientName, patientPhone: phone, message, returnDate, notes }\n}];"
      },
